#!/bin/bash
set -euo pipefail

# The UNIX philosophy: One tool, one job
MODE=""
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

check_root() {
    if [[ "$EUID" -ne 0 ]]; then
        echo "[ERROR] This script must be run as root (sudo)."
        exit 1
    fi
}

dispatch() {
    case "$MODE" in
        auto)
            [[ -f "$SCRIPT_DIR/scripts/install_auto.sh" ]] || { echo "Auto script missing"; exit 1; }
            chmod +x "$SCRIPT_DIR/scripts/install_auto.sh"
            exec "$SCRIPT_DIR/scripts/install_auto.sh"
            ;;
        manual)
            [[ -f "$SCRIPT_DIR/scripts/install_manual.sh" ]] || { echo "Manual script missing"; exit 1; }
            chmod +x "$SCRIPT_DIR/scripts/install_manual.sh"
            exec "$SCRIPT_DIR/scripts/install_manual.sh"
            ;;
        *)
            echo "Usage: ./install [-a|--auto] [-m|--manual]"
            exit 1
            ;;
    esac
}

check_root

while [[ $# -gt 0 ]]; do
    case "$1" in
        -a|--auto)   MODE="auto"; shift ;;
        -m|--manual) MODE="manual"; shift ;;
        -h|--help)   echo "Usage: ./install [-a|--auto] [-m|--manual]"; exit 0 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

dispatch
